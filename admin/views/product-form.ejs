<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product ? 'Edit' : 'Add' %> Product — Commenhers Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Lato, sans-serif; background: #f4f6f4; color: #333; }
    .topbar { background: #2e7d32; color: #fff; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    .topbar h1 { font-size: 1.1rem; }
    .topbar a { color: #fff; font-size: 0.85rem; text-decoration: none; opacity: .8; }
    .topbar a:hover { opacity: 1; }
    .main { max-width: 640px; margin: 40px auto; padding: 0 24px; }
    h2 { font-size: 1.4rem; color: #2e7d32; margin-bottom: 28px; }
    .form-card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.08); padding: 32px; }
    .form-group { margin-bottom: 20px; }
    label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 6px; color: #444; }
    input[type="text"], input[type="number"], select { width: 100%; padding: 10px 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 0.95rem; }
    input:focus, select:focus { outline: none; border-color: #2e7d32; }
    .checkbox-group { display: flex; align-items: center; gap: 10px; }
    .checkbox-group input { width: auto; }
    .checkbox-group label { margin: 0; font-weight: 400; }
    .hint { font-size: 0.78rem; color: #888; margin-top: 4px; }
    .actions { display: flex; gap: 12px; margin-top: 28px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 4px; font-size: 0.95rem; font-weight: 700; text-decoration: none; cursor: pointer; border: none; }
    .btn-green { background: #2e7d32; color: #fff; }
    .btn-green:hover { background: #1b5e20; }
    .btn-outline { background: #fff; border: 1px solid #ccc; color: #555; }
    .btn-outline:hover { border-color: #2e7d32; color: #2e7d32; }
    .error { background: #fdecea; color: #c62828; border-radius: 4px; padding: 10px 14px; margin-bottom: 20px; font-size: 0.9rem; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Commenhers Admin</h1>
    <div style="display:flex;gap:20px;align-items:center;">
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/products">Products</a>
      <a href="/admin/orders">Orders</a>
      <a href="/admin/content">Content</a>
      <a href="/" target="_blank">View Site ↗</a>
      <a href="/admin/logout">Logout</a>
    </div>
  </div>
  <div class="main">
    <h2><%= product ? 'Edit Product' : 'Add Product' %></h2>
    <div class="form-card">
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form method="POST" action="<%= product ? '/admin/products/' + product.id : '/admin/products' %>" enctype="multipart/form-data">
        <div class="form-group">
          <label for="name">Product Name *</label>
          <input type="text" id="name" name="name" value="<%= product ? product.name : '' %>" required>
        </div>
        <div class="form-group">
          <label for="price">Price (SGD) *</label>
          <input type="number" id="price" name="price" value="<%= product ? product.price : '' %>" step="0.01" min="0" required>
        </div>
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category">
            <% const cats = ['bags','accessories','workshops','uncategorised']; %>
            <% cats.forEach(c => { %>
              <option value="<%= c %>" <%= (product && product.category === c) ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="imageFile">Product Image</label>
          <% if (product && product.image) { %>
            <img src="/<%= product.image %>" alt="Current image" style="display:block;max-width:180px;max-height:120px;object-fit:cover;border-radius:4px;border:1px solid #ddd;margin-bottom:10px;">
          <% } %>
          <input type="file" id="imageFile" name="imageFile" accept="image/*">
          <input type="hidden" name="existingImage" value="<%= product ? product.image : '' %>">
          <p class="hint">Upload an image file. If left blank, the current image is kept.</p>
        </div>
        <div class="form-group">
          <div class="checkbox-group">
            <input type="checkbox" id="soldOut" name="soldOut" <%= (product && product.soldOut) ? 'checked' : '' %>>
            <label for="soldOut">Mark as Sold Out</label>
          </div>
        </div>
        <div class="actions">
          <button type="submit" class="btn btn-green"><%= product ? 'Save Changes' : 'Add Product' %></button>
          <a href="/admin/products" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
