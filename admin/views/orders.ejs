<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders — Commenhers Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Lato, sans-serif; background: #f4f6f4; color: #333; }
    .topbar { background: #2e7d32; color: #fff; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    .topbar h1 { font-size: 1.1rem; }
    .topbar nav { display: flex; gap: 20px; align-items: center; }
    .topbar a { color: #fff; font-size: 0.85rem; text-decoration: none; opacity: .8; }
    .topbar a:hover { opacity: 1; }
    .main { max-width: 1100px; margin: 40px auto; padding: 0 24px; }
    h2 { font-size: 1.4rem; margin-bottom: 24px; color: #2e7d32; }
    .empty { color: #888; font-size: 0.95rem; padding: 40px 0; text-align: center; }
    table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
    th { background: #2e7d32; color: #fff; padding: 12px 16px; text-align: left; font-size: 0.85rem; font-weight: 700; }
    td { padding: 12px 16px; border-bottom: 1px solid #f0f0f0; font-size: 0.9rem; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f9fdf9; }
    .items-list { list-style: none; font-size: 0.82rem; color: #555; }
    .items-list li { padding: 1px 0; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; }
    .badge-pending  { background: #fff3cd; color: #856404; }
    .badge-confirmed { background: #d1ecf1; color: #0c5460; }
    .badge-shipped  { background: #cce5ff; color: #004085; }
    .badge-delivered { background: #d4edda; color: #155724; }
    .badge-cancelled { background: #f8d7da; color: #721c24; }
    select { font-size: 0.82rem; padding: 4px 8px; border: 1px solid #ccc; border-radius: 4px; }
    button[type=submit] { background: #2e7d32; color: #fff; border: none; padding: 5px 12px; border-radius: 4px; font-size: 0.82rem; cursor: pointer; margin-left: 6px; }
    button[type=submit]:hover { background: #1b5e20; }
    .total-col { white-space: nowrap; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Commenhers Admin</h1>
    <nav>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/products">Products</a>
      <a href="/admin/orders">Orders</a>
      <a href="/admin/content">Content</a>
      <a href="/" target="_blank">View Site ↗</a>
      <a href="/admin/logout">Logout</a>
    </nav>
  </div>
  <div class="main">
    <h2>Orders (<%= orders.length %>)</h2>

    <% if (orders.length === 0) { %>
      <p class="empty">No orders yet.</p>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Items</th>
          <th>Total</th>
          <th>Status</th>
          <th>Update</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(order => { %>
        <tr>
          <td><%= new Date(order.createdAt).toLocaleDateString('en-SG', { day:'2-digit', month:'short', year:'numeric' }) %></td>
          <td style="font-family:monospace;font-size:0.8rem;">#<%= order.id.slice(-6) %></td>
          <td>
            <strong><%= order.name %></strong><br>
            <span style="font-size:0.8rem;color:#666;"><%= order.email %></span><br>
            <% if (order.phone) { %><span style="font-size:0.8rem;color:#666;"><%= order.phone %></span><% } %>
          </td>
          <td>
            <ul class="items-list">
              <% order.items.forEach(item => { %>
              <li>× <%= item.qty %> <%= item.name %> ($<%= Number(item.price).toFixed(2) %>)</li>
              <% }) %>
            </ul>
          </td>
          <td class="total-col"><strong>$<%= Number(order.total).toFixed(2) %></strong></td>
          <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
          <td>
            <form method="POST" action="/admin/orders/<%= order.id %>/status" style="display:flex;align-items:center;">
              <select name="status">
                <option value="pending"   <%= order.status==='pending'   ? 'selected':'' %>>Pending</option>
                <option value="confirmed" <%= order.status==='confirmed' ? 'selected':'' %>>Confirmed</option>
                <option value="shipped"   <%= order.status==='shipped'   ? 'selected':'' %>>Shipped</option>
                <option value="delivered" <%= order.status==='delivered' ? 'selected':'' %>>Delivered</option>
                <option value="cancelled" <%= order.status==='cancelled' ? 'selected':'' %>>Cancelled</option>
              </select>
              <button type="submit">Save</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</body>
</html>
