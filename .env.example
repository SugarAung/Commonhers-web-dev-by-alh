# Copy this file to .env and fill in your values
# Never commit .env to git

# Generate a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-long-random-string

# Admin login credentials
ADMIN_USER=admin
# Generate hash: node -e "require('bcrypt').hash('yourpassword',10).then(h=>console.log(h))"
ADMIN_PASS_HASH=<paste-bcrypt-hash-here>

# Server port
PORT=3000

# Stripe keys — get these from the Commenhers Stripe account dashboard
# Test keys start with sk_test_ / pk_test_
# Live keys start with sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
